# Copy this file to .env — NEVER commit .env
#
# 1. Create the test vault (if it doesn't already exist):
#      op vault create nix-op-secrets-test
#
# 2. Generate a 1Password service account token:
#    https://developer.1password.com/docs/service-accounts/
#
#    IMPORTANT: After generating the token, you must explicitly grant the
#    service account access to the "nix-op-secrets-test" vault. The token
#    does NOT automatically inherit vault access — even if the token owner
#    created the vault.
#
#    Grant access via the 1Password web UI:
#      a. Sign in at https://start.1password.com
#      b. Navigate to Developer Tools → Service Accounts
#      c. Select your service account
#      d. Under "Vault Access", click "Add vault" and add "nix-op-secrets-test"
#         with at minimum Read & Write permissions
#
# 3. Place this file at the repo root as .env before running:
#      ./scripts/test-vm.sh

OP_SERVICE_ACCOUNT_TOKEN=ops_your_token_here
