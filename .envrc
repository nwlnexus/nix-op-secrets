#!/usr/bin/env bash
# .envrc — direnv loads this locally; CI sources it with OP_SERVICE_ACCOUNT_TOKEN set
# Reads secrets from 1Password and generates .env files for each workspace

# Source .env files for local overrides. This setup works with both direnv (`direnv allow`)
# and interactive sourcing (`source .envrc`), ensuring variables are exported to the parent shell
# (as required by both methods).

# Export all variables set/sourced within this block
set -a

if [ -f "${HOME}/projects/personal/.env" ]; then
  # shellcheck source=/dev/null
  . "${HOME}/projects/personal/.env"
fi

if [ -f ".env" ]; then
  # shellcheck source=/dev/null
  . ".env"
fi

set +a